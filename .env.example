# Urban Intervention Tool - Environment Variables
# Copy this file to backend/.env and fill in your API keys

# ============================================
# REQUIRED: Anthropic Claude API
# ============================================
# Get your API key from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE

# ============================================
# OPTIONAL: OpenAI DALL-E Image Generation
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
# Note: Requires paid account with credits
OPENAI_API_KEY=sk-YOUR_API_KEY_HERE

# ============================================
# RAG (Retrieval-Augmented Generation) Settings
# ============================================
# Similarity threshold for RAG case retrieval (0.0 - 1.0)
# Higher = stricter matching (default 0.6)
RAG_SIMILARITY_THRESHOLD=0.6

# Embedding model for RAG (local, no API key needed)
# Options: all-MiniLM-L6-v2 (fast, good quality)
#          all-mpnet-base-v2 (slower, better quality)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================
# Infrared API (Existing - kept for reference)
# ============================================
# INFRARED_API_KEY=your_infrared_api_key
# INFRARED_BASE_URL=https://api.infrared.city/v2

# ============================================
# Optional: Model Configuration
# ============================================
# Claude model version
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# LLM max tokens (higher = more detailed but slower)
# LLM_MAX_TOKENS=2000

# Image generation quality
# IMAGE_QUALITY=hd  # or 'standard' for faster, cheaper
