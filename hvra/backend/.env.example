# Copy this file to .env and fill in your values, then restart uvicorn.

# ── REQUIRED — Stage 3 + 4b — LLM diagnosis and retrofit shortlist ──────
# Anthropic API key — https://console.anthropic.com → API Keys
# Used by default (LLM_PROVIDER unset / not "ollama"). Without this AND
# without LLM_PROVIDER=ollama below, Stage 3 (diagnosis) and Stage 4b
# (shortlist) are skipped — rooms get scores but no AI-written diagnosis
# or retrofit recommendations.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── OPTIONAL — local LLM instead of Claude (no cost, lower quality) ─────
# Uncomment LLM_PROVIDER to use a free local model via Ollama instead of
# the Anthropic API. Requires Ollama installed and running:
#   https://ollama.com  →  ollama pull llama3.2:3b
#LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:3b
OLLAMA_CONCURRENCY=2
#OLLAMA_URL=http://localhost:11434

# ── OPTIONAL — Stage 5b — AI "after retrofit" photorealistic rendering ──
# Without these two keys, the "Render this strategy" button in the UI
# will fail with a clear error — every other feature works fine without them.

# Gemini API key — https://aistudio.google.com → Get API key
# Used for image-to-image editing (adds the retrofit element to a facade
# photo). Requires billing enabled on the Google Cloud project — image
# generation is not available on the no-billing free tier.
GEMINI_API_KEY=your-gemini-api-key-here

# Google Maps API key, reused for the Street View Static API — same key as
# frontend/.env's VITE_GOOGLE_MAPS_API_KEY works, but that project must have
# "Street View Static API" enabled (Maps JavaScript API alone is not enough).
# Falls back to a 3D viewport screenshot (sent from the frontend) if Street
# View has no coverage for the building's coordinates, or this key is unset.
GOOGLE_STREETVIEW_API_KEY=your-google-maps-api-key-here
