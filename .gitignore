# Secrets — never commit API keys
.env
*.env
!.env.example

# Dependencies
node_modules/
backend/venv/

# Building-level backend (vendored subtree) — local venv, runtime uploads & logs.
# Keep these out of git so `git subtree pull` stays clean.
building-level/**/.venv/
building-level/**/venv/
building-level/**/uploads/
building-level/**/*.log

# Python artifacts
__pycache__/
*.pyc
*.pyo

# Build output
frontend/dist/

# Runtime artifacts
backend/cache/
backend/*.log
backend/debug_coordinates.txt
backend/data/uploads/

# Copyrighted research PDFs (RAG corpus) — keep local only
backend/data/documents/
backend/data/documents_index.json

# Archived unused files
_archive_unused/

# Local test IFC models (downloaded samples to share, not part of the repo)
test-ifc/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
